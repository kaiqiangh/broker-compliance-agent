# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/broker_compliance"

# Auth — CHANGE THESE IN PRODUCTION
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Redis (optional — falls back to in-memory if not set; required for multi-instance)
REDIS_URL="redis://localhost:6379"

# Email (Resend) — get API key from https://resend.com
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="noreply@yourdomain.ie"

# App URL (for email links)
APP_URL="http://localhost:3000"

# Cloudflare R2 (optional, for file storage)
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_ACCOUNT_ID=""
